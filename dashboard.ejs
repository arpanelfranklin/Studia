<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Today's Schedule</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="dashboard.css">

</head>

<body>


    <div class="sidebar">
        <div class="user-info">
            <img src="pfp.jpg" alt="Amelia">
            <div>
                <h3>Hi, <%= username %>
                </h3>
                <p>Student</p>
            </div>
        </div>
        <ul class="nav-menu">
            <li class="nav-item">
                <a href="#" class="active">
                    <i class="fas fa-home"></i> Home
                </a>
            </li>
            <li class="nav-item">
                <a href="#">
                    <i class="fas fa-calendar-check"></i> Attendance
                </a>
            </li>
            <li class="nav-item">
                <a href="#">
                    <i class="fas fa-tasks"></i> Tasks
                </a>
            </li>
            <li class="nav-item">
                <a href="#">
                    <i class="fas fa-clock"></i> Routine
                </a>
            </li>
            <li class="nav-item">
                <a href="#">
                    <i class="fas fa-cog"></i> Settings
                </a>
            </li>
        </ul>
    </div>
    <div class="main-content">
        <h2 class="page-title">Today</h2>

        <div class="section">
            <h3 class="section-title">Schedule</h3>
            <div class="card schedule-card">
                <div class="card-left">
                    <div class="card-icon-bg">
                        <i class="fas fa-book-open"></i>
                    </div>
                    <div class="card-content">
                        <h4>Calculus</h4>
                        <p>9:00 AM - 10:00 AM</p>
                    </div>
                </div>
            </div>
            <div class="card schedule-card">
                <div class="card-left">
                    <div class="card-icon-bg">
                        <i class="fas fa-atom"></i>
                    </div>
                    <div class="card-content">
                        <h4>Physics</h4>
                        <p>10:00 AM - 11:00 AM</p>
                    </div>
                </div>
            </div>
            <div class="card schedule-card break">
                <div class="card-left">
                    <div class="card-icon-bg">
                        <i class="fas fa-coffee"></i>
                    </div>
                    <div class="card-content">
                        <h4>Break</h4>
                        <p>11:00 AM - 12:00 PM</p>
                    </div>
                </div>
            </div>
            <div class="card schedule-card">
                <div class="card-left">
                    <div class="card-icon-bg">
                        <i class="fas fa-flask"></i>
                    </div>
                    <div class="card-content">
                        <h4>Chemistry</h4>
                        <p>12:00 PM - 1:00 PM</p>
                    </div>
                </div>
            </div>
            <div class="card schedule-card lunch">
                <div class="card-left">
                    <div class="card-icon-bg">
                        <i class="fas fa-utensils"></i>
                    </div>
                    <div class="card-content">
                        <h4>Lunch</h4>
                        <p>1:00 PM - 2:00 PM</p>
                    </div>
                </div>
            </div>
            <div class="card schedule-card">
                <div class="card-left">
                    <div class="card-icon-bg">
                        <i class="fas fa-pencil-alt"></i>
                    </div>
                    <div class="card-content">
                        <h4>English</h4>
                        <p>2:00 PM - 3:00 PM</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="section">
            <h3 class="section-title">Attendance</h3>
            <div class="card attendance-card">
                <div class="card-left">
                    <div class="card-icon-bg">
                        <i class="fas fa-book-open"></i>
                    </div>
                    <div class="card-content">
                        <h4>Calculus</h4>
                        <p>Present</p>
                    </div>
                </div>
                <div class="green-dot"></div>
            </div>
            <div class="card attendance-card">
                <div class="card-left">
                    <div class="card-icon-bg">
                        <i class="fas fa-atom"></i>
                    </div>
                    <div class="card-content">
                        <h4>Physics</h4>
                        <p>Present</p>
                    </div>
                </div>
                <div class="green-dot"></div>
            </div>
            <div class="card attendance-card">
                <div class="card-left">
                    <div class="card-icon-bg">
                        <i class="fas fa-flask"></i>
                    </div>
                    <div class="card-content">
                        <h4>Chemistry</h4>
                        <p>Present</p>
                    </div>
                </div>
                <div class="green-dot"></div>
            </div>
            <div class="card attendance-card">
                <div class="card-left">
                    <div class="card-icon-bg">
                        <i class="fas fa-pencil-alt"></i>
                    </div>
                    <div class="card-content">
                        <h4>English</h4>
                        <p>Present</p>
                    </div>
                </div>
                <div class="green-dot"></div>
            </div>
        </div>

        <div class="section">
            <h3 class="section-title">Tasks</h3>
            <div class="card task-card">
                <div class="card-left">
                    <div class="card-icon-bg">
                        <i class="fas fa-book-open"></i>
                    </div>
                    <div class="card-content">
                        <h4>Calculus Assignment</h4>
                        <p>Due today</p>
                    </div>
                </div>
                <div class="green-dot"></div>
            </div>
            <div class="card task-card">
                <div class="card-left">
                    <div class="card-icon-bg">
                        <i class="fas fa-atom"></i>
                    </div>
                    <div class="card-content">
                        <h4>Physics Lab Report</h4>
                        <p>Due today</p>
                    </div>
                </div>
                <div class="green-dot"></div>
            </div>
            <div class="card task-card">
                <div class="card-left">
                    <div class="card-icon-bg">
                        <i class="fas fa-flask"></i>
                    </div>
                    <div class="card-content">
                        <h4>Chemistry Quiz</h4>
                        <p>Due today</p>
                    </div>
                </div>
                <div class="green-dot"></div>
            </div>
            <div class="card task-card">
                <div class="card-left">
                    <div class="card-icon-bg">
                        <i class="fas fa-pencil-alt"></i>
                    </div>
                    <div class="card-content">
                        <h4>English Essay</h4>
                        <p>Due today</p>
                    </div>
                </div>
                <div class="green-dot"></div>
            </div>
        </div>

    </div>
</body>

</html>