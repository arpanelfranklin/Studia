<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Curriculum - EduPortal</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        coral: '#FF6B6B',
                        teal: '#4ECDC4'
                    }
                }
            }
        }
    </script>
    <style>
        .course-card {
            transition: all 0.3s ease;
        }

        .course-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
        }

        .semester-timeline {
            position: relative;
        }

        .semester-timeline::before {
            content: '';
            position: absolute;
            left: 20px;
            top: 0;
            bottom: 0;
            width: 2px;
            background: linear-gradient(to bottom, #FF6B6B, #4ECDC4);
        }

        .timeline-dot {
            position: relative;
            z-index: 10;
        }
    </style>
</head>

<body class="bg-gray-50 min-h-screen">
    <!-- Header -->
    <header class="bg-white shadow-sm border-b-2 border-teal">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center py-4">
                <div class="flex items-center space-x-3">
                    <div
                        class="w-10 h-10 bg-gradient-to-r from-coral to-teal rounded-lg flex items-center justify-center">
                        <span class="text-white font-bold text-lg">📚</span>
                    </div>
                    <h1 class="text-2xl font-bold text-gray-800">EduPortal</h1>
                </div>
                <div class="flex items-center space-x-6">
                    <nav class="hidden md:flex space-x-6">
                        <a href="#" class="text-gray-600 hover:text-coral transition-colors">Dashboard</a>
                        <a href="#" class="text-gray-600 hover:text-coral transition-colors">Grades</a>
                        <a href="#" class="text-coral font-medium">Curriculum</a>
                        <a href="#" class="text-gray-600 hover:text-coral transition-colors">Schedule</a>
                    </nav>
                    <div class="flex items-center space-x-4">
                        <span class="text-gray-600">Welcome back, Alex!</span>
                        <div class="w-8 h-8 bg-teal rounded-full flex items-center justify-center">
                            <span class="text-white text-sm font-semibold">A</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <!-- Page Header -->
        <div class="mb-8">
            <h2 class="text-3xl font-bold text-gray-900 mb-2">Computer Science Curriculum</h2>
            <p class="text-gray-600">Bachelor of Science in Computer Science • 4-Year Program</p>

            <!-- Program Overview -->
            <div class="mt-6 grid grid-cols-1 md:grid-cols-4 gap-4">
                <div class="bg-white rounded-lg p-4 border border-gray-200">
                    <div class="text-2xl font-bold text-coral">120</div>
                    <div class="text-sm text-gray-600">Total Credits</div>
                </div>
                <div class="bg-white rounded-lg p-4 border border-gray-200">
                    <div class="text-2xl font-bold text-teal">8</div>
                    <div class="text-sm text-gray-600">Semesters</div>
                </div>
                <div class="bg-white rounded-lg p-4 border border-gray-200">
                    <div class="text-2xl font-bold text-coral">45</div>
                    <div class="text-sm text-gray-600">Core Courses</div>
                </div>
                <div class="bg-white rounded-lg p-4 border border-gray-200">
                    <div class="text-2xl font-bold text-teal">15</div>
                    <div class="text-sm text-gray-600">Electives</div>
                </div>
            </div>
        </div>

        <!-- Year Tabs -->
        <div class="mb-8">
            <div class="flex space-x-1 bg-gray-100 p-1 rounded-lg w-fit">
                <button class="year-tab px-6 py-3 rounded-md bg-white text-coral font-medium shadow-sm"
                    data-year="1">Year 1</button>
                <button class="year-tab px-6 py-3 rounded-md text-gray-600 hover:text-gray-800" data-year="2">Year
                    2</button>
                <button class="year-tab px-6 py-3 rounded-md text-gray-600 hover:text-gray-800" data-year="3">Year
                    3</button>
                <button class="year-tab px-6 py-3 rounded-md text-gray-600 hover:text-gray-800" data-year="4">Year
                    4</button>
            </div>
        </div>

        <!-- Year 1 Content -->
        <div class="year-content" id="year-1">
            <div class="semester-timeline space-y-8">
                <!-- Fall Semester -->
                <div class="flex items-start space-x-6">
                    <div
                        class="timeline-dot w-10 h-10 bg-coral rounded-full flex items-center justify-center text-white font-semibold">
                        F1
                    </div>
                    <div class="flex-1">
                        <h3 class="text-xl font-semibold text-gray-900 mb-4">Fall Semester - Year 1</h3>
                        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                            <div class="course-card bg-white rounded-lg p-4 border border-gray-200">
                                <div class="flex items-center space-x-3 mb-3">
                                    <div class="w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center">
                                        <span class="text-xl">💻</span>
                                    </div>
                                    <div>
                                        <h4 class="font-semibold text-gray-900">Intro to Programming</h4>
                                        <p class="text-sm text-gray-500">CS 101 • 3 Credits</p>
                                    </div>
                                </div>
                                <p class="text-sm text-gray-600 mb-2">Fundamentals of programming using Python.
                                    Variables, loops, functions, and basic algorithms.</p>
                                <div class="flex items-center justify-between">
                                    <span class="text-xs bg-blue-100 text-blue-800 px-2 py-1 rounded">Core</span>
                                    <span class="text-xs text-gray-500">Prerequisites: None</span>
                                </div>
                            </div>

                            <div class="course-card bg-white rounded-lg p-4 border border-gray-200">
                                <div class="flex items-center space-x-3 mb-3">
                                    <div class="w-10 h-10 bg-green-100 rounded-lg flex items-center justify-center">
                                        <span class="text-xl">📐</span>
                                    </div>
                                    <div>
                                        <h4 class="font-semibold text-gray-900">Calculus I</h4>
                                        <p class="text-sm text-gray-500">MATH 151 • 4 Credits</p>
                                    </div>
                                </div>
                                <p class="text-sm text-gray-600 mb-2">Limits, derivatives, and applications. Foundation
                                    for advanced mathematics in computer science.</p>
                                <div class="flex items-center justify-between">
                                    <span class="text-xs bg-green-100 text-green-800 px-2 py-1 rounded">Math</span>
                                    <span class="text-xs text-gray-500">Prerequisites: Pre-calc</span>
                                </div>
                            </div>

                            <div class="course-card bg-white rounded-lg p-4 border border-gray-200">
                                <div class="flex items-center space-x-3 mb-3">
                                    <div class="w-10 h-10 bg-purple-100 rounded-lg flex items-center justify-center">
                                        <span class="text-xl">📖</span>
                                    </div>
                                    <div>
                                        <h4 class="font-semibold text-gray-900">English Composition</h4>
                                        <p class="text-sm text-gray-500">ENG 101 • 3 Credits</p>
                                    </div>
                                </div>
                                <p class="text-sm text-gray-600 mb-2">Academic writing, research methods, and
                                    communication skills essential for technical fields.</p>
                                <div class="flex items-center justify-between">
                                    <span class="text-xs bg-purple-100 text-purple-800 px-2 py-1 rounded">General
                                        Ed</span>
                                    <span class="text-xs text-gray-500">Prerequisites: None</span>
                                </div>
                            </div>

                            <div class="course-card bg-white rounded-lg p-4 border border-gray-200">
                                <div class="flex items-center space-x-3 mb-3">
                                    <div class="w-10 h-10 bg-red-100 rounded-lg flex items-center justify-center">
                                        <span class="text-xl">⚛️</span>
                                    </div>
                                    <div>
                                        <h4 class="font-semibold text-gray-900">Physics I</h4>
                                        <p class="text-sm text-gray-500">PHYS 201 • 4 Credits</p>
                                    </div>
                                </div>
                                <p class="text-sm text-gray-600 mb-2">Mechanics, waves, and thermodynamics. Scientific
                                    foundation for computing systems.</p>
                                <div class="flex items-center justify-between">
                                    <span class="text-xs bg-red-100 text-red-800 px-2 py-1 rounded">Science</span>
                                    <span class="text-xs text-gray-500">Prerequisites: Calculus I</span>
                                </div>
                            </div>

                            <div class="course-card bg-white rounded-lg p-4 border border-gray-200">
                                <div class="flex items-center space-x-3 mb-3">
                                    <div class="w-10 h-10 bg-yellow-100 rounded-lg flex items-center justify-center">
                                        <span class="text-xl">🎨</span>
                                    </div>
                                    <div>
                                        <h4 class="font-semibold text-gray-900">Digital Design</h4>
                                        <p class="text-sm text-gray-500">ART 105 • 3 Credits</p>
                                    </div>
                                </div>
                                <p class="text-sm text-gray-600 mb-2">Introduction to visual design principles, color
                                    theory, and digital media creation.</p>
                                <div class="flex items-center justify-between">
                                    <span
                                        class="text-xs bg-yellow-100 text-yellow-800 px-2 py-1 rounded">Elective</span>
                                    <span class="text-xs text-gray-500">Prerequisites: None</span>
                                </div>
                            </div>
                        </div>
                        <div class="mt-4 text-right">
                            <span class="text-sm font-medium text-gray-600">Total Credits: 17</span>
                        </div>
                    </div>
                </div>

                <!-- Spring Semester -->
                <div class="flex items-start space-x-6">
                    <div
                        class="timeline-dot w-10 h-10 bg-teal rounded-full flex items-center justify-center text-white font-semibold">
                        S1
                    </div>
                    <div class="flex-1">
                        <h3 class="text-xl font-semibold text-gray-900 mb-4">Spring Semester - Year 1</h3>
                        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                            <div class="course-card bg-white rounded-lg p-4 border border-gray-200">
                                <div class="flex items-center space-x-3 mb-3">
                                    <div class="w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center">
                                        <span class="text-xl">🔧</span>
                                    </div>
                                    <div>
                                        <h4 class="font-semibold text-gray-900">Data Structures</h4>
                                        <p class="text-sm text-gray-500">CS 102 • 3 Credits</p>
                                    </div>
                                </div>
                                <p class="text-sm text-gray-600 mb-2">Arrays, linked lists, stacks, queues, trees, and
                                    graphs. Algorithm analysis and implementation.</p>
                                <div class="flex items-center justify-between">
                                    <span class="text-xs bg-blue-100 text-blue-800 px-2 py-1 rounded">Core</span>
                                    <span class="text-xs text-gray-500">Prerequisites: CS 101</span>
                                </div>
                            </div>

                            <div class="course-card bg-white rounded-lg p-4 border border-gray-200">
                                <div class="flex items-center space-x-3 mb-3">
                                    <div class="w-10 h-10 bg-green-100 rounded-lg flex items-center justify-center">
                                        <span class="text-xl">📊</span>
                                    </div>
                                    <div>
                                        <h4 class="font-semibold text-gray-900">Calculus II</h4>
                                        <p class="text-sm text-gray-500">MATH 152 • 4 Credits</p>
                                    </div>
                                </div>
                                <p class="text-sm text-gray-600 mb-2">Integration techniques, sequences, series, and
                                    multivariable calculus introduction.</p>
                                <div class="flex items-center justify-between">
                                    <span class="text-xs bg-green-100 text-green-800 px-2 py-1 rounded">Math</span>
                                    <span class="text-xs text-gray-500">Prerequisites: MATH 151</span>
                                </div>
                            </div>

                            <div class="course-card bg-white rounded-lg p-4 border border-gray-200">
                                <div class="flex items-center space-x-3 mb-3">
                                    <div class="w-10 h-10 bg-indigo-100 rounded-lg flex items-center justify-center">
                                        <span class="text-xl">🔌</span>
                                    </div>
                                    <div>
                                        <h4 class="font-semibold text-gray-900">Digital Logic</h4>
                                        <p class="text-sm text-gray-500">CS 150 • 3 Credits</p>
                                    </div>
                                </div>
                                <p class="text-sm text-gray-600 mb-2">Boolean algebra, logic gates, combinational and
                                    sequential circuits, computer architecture basics.</p>
                                <div class="flex items-center justify-between">
                                    <span class="text-xs bg-blue-100 text-blue-800 px-2 py-1 rounded">Core</span>
                                    <span class="text-xs text-gray-500">Prerequisites: None</span>
                                </div>
                            </div>

                            <div class="course-card bg-white rounded-lg p-4 border border-gray-200">
                                <div class="flex items-center space-x-3 mb-3">
                                    <div class="w-10 h-10 bg-orange-100 rounded-lg flex items-center justify-center">
                                        <span class="text-xl">🗣️</span>
                                    </div>
                                    <div>
                                        <h4 class="font-semibold text-gray-900">Public Speaking</h4>
                                        <p class="text-sm text-gray-500">COMM 101 • 3 Credits</p>
                                    </div>
                                </div>
                                <p class="text-sm text-gray-600 mb-2">Oral communication skills, presentation
                                    techniques, and professional communication.</p>
                                <div class="flex items-center justify-between">
                                    <span class="text-xs bg-purple-100 text-purple-800 px-2 py-1 rounded">General
                                        Ed</span>
                                    <span class="text-xs text-gray-500">Prerequisites: ENG 101</span>
                                </div>
                            </div>

                            <div class="course-card bg-white rounded-lg p-4 border border-gray-200">
                                <div class="flex items-center space-x-3 mb-3">
                                    <div class="w-10 h-10 bg-pink-100 rounded-lg flex items-center justify-center">
                                        <span class="text-xl">🧠</span>
                                    </div>
                                    <div>
                                        <h4 class="font-semibold text-gray-900">Psychology</h4>
                                        <p class="text-sm text-gray-500">PSYC 101 • 3 Credits</p>
                                    </div>
                                </div>
                                <p class="text-sm text-gray-600 mb-2">Introduction to human behavior, cognition, and
                                    psychological principles relevant to HCI.</p>
                                <div class="flex items-center justify-between">
                                    <span class="text-xs bg-purple-100 text-purple-800 px-2 py-1 rounded">General
                                        Ed</span>
                                    <span class="text-xs text-gray-500">Prerequisites: None</span>
                                </div>
                            </div>
                        </div>
                        <div class="mt-4 text-right">
                            <span class="text-sm font-medium text-gray-600">Total Credits: 16</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Year 2 Content (Hidden by default) -->
        <div class="year-content hidden" id="year-2">
            <div class="semester-timeline space-y-8">
                <div class="flex items-start space-x-6">
                    <div
                        class="timeline-dot w-10 h-10 bg-coral rounded-full flex items-center justify-center text-white font-semibold">
                        F2
                    </div>
                    <div class="flex-1">
                        <h3 class="text-xl font-semibold text-gray-900 mb-4">Fall Semester - Year 2</h3>
                        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                            <div class="course-card bg-white rounded-lg p-4 border border-gray-200">
                                <div class="flex items-center space-x-3 mb-3">
                                    <div class="w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center">
                                        <span class="text-xl">🔍</span>
                                    </div>
                                    <div>
                                        <h4 class="font-semibold text-gray-900">Algorithms</h4>
                                        <p class="text-sm text-gray-500">CS 201 • 3 Credits</p>
                                    </div>
                                </div>
                                <p class="text-sm text-gray-600 mb-2">Algorithm design and analysis, sorting, searching,
                                    graph algorithms, dynamic programming.</p>
                                <div class="flex items-center justify-between">
                                    <span class="text-xs bg-blue-100 text-blue-800 px-2 py-1 rounded">Core</span>
                                    <span class="text-xs text-gray-500">Prerequisites: CS 102</span>
                                </div>
                            </div>

                            <div class="course-card bg-white rounded-lg p-4 border border-gray-200">
                                <div class="flex items-center space-x-3 mb-3">
                                    <div class="w-10 h-10 bg-indigo-100 rounded-lg flex items-center justify-center">
                                        <span class="text-xl">🏗️</span>
                                    </div>
                                    <div>
                                        <h4 class="font-semibold text-gray-900">Computer Architecture</h4>
                                        <p class="text-sm text-gray-500">CS 250 • 3 Credits</p>
                                    </div>
                                </div>
                                <p class="text-sm text-gray-600 mb-2">CPU design, memory systems, instruction sets,
                                    performance analysis, and assembly language.</p>
                                <div class="flex items-center justify-between">
                                    <span class="text-xs bg-blue-100 text-blue-800 px-2 py-1 rounded">Core</span>
                                    <span class="text-xs text-gray-500">Prerequisites: CS 150</span>
                                </div>
                            </div>

                            <div class="course-card bg-white rounded-lg p-4 border border-gray-200">
                                <div class="flex items-center space-x-3 mb-3">
                                    <div class="w-10 h-10 bg-green-100 rounded-lg flex items-center justify-center">
                                        <span class="text-xl">📈</span>
                                    </div>
                                    <div>
                                        <h4 class="font-semibold text-gray-900">Statistics</h4>
                                        <p class="text-sm text-gray-500">STAT 201 • 3 Credits</p>
                                    </div>
                                </div>
                                <p class="text-sm text-gray-600 mb-2">Probability, statistical inference, hypothesis
                                    testing, and data analysis methods.</p>
                                <div class="flex items-center justify-between">
                                    <span class="text-xs bg-green-100 text-green-800 px-2 py-1 rounded">Math</span>
                                    <span class="text-xs text-gray-500">Prerequisites: MATH 152</span>
                                </div>
                            </div>
                        </div>
                        <div class="mt-4 text-right">
                            <span class="text-sm font-medium text-gray-600">Total Credits: 15</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Degree Requirements Summary -->
        <div class="mt-12 bg-white rounded-xl p-6 shadow-sm border border-gray-100">
            <h3 class="text-xl font-semibold text-gray-900 mb-6">Degree Requirements Summary</h3>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
                <div class="text-center">
                    <div
                        class="w-16 h-16 bg-gradient-to-r from-coral to-teal rounded-full flex items-center justify-center mx-auto mb-3">
                        <span class="text-white text-2xl">💻</span>
                    </div>
                    <h4 class="font-semibold text-gray-900 mb-2">Core CS Courses</h4>
                    <p class="text-2xl font-bold text-coral mb-1">45 Credits</p>
                    <p class="text-sm text-gray-600">Programming, algorithms, systems</p>
                </div>

                <div class="text-center">
                    <div
                        class="w-16 h-16 bg-gradient-to-r from-teal to-coral rounded-full flex items-center justify-center mx-auto mb-3">
                        <span class="text-white text-2xl">📐</span>
                    </div>
                    <h4 class="font-semibold text-gray-900 mb-2">Mathematics</h4>
                    <p class="text-2xl font-bold text-teal mb-1">18 Credits</p>
                    <p class="text-sm text-gray-600">Calculus, statistics, discrete math</p>
                </div>

                <div class="text-center">
                    <div
                        class="w-16 h-16 bg-gradient-to-r from-coral to-teal rounded-full flex items-center justify-center mx-auto mb-3">
                        <span class="text-white text-2xl">🌟</span>
                    </div>
                    <h4 class="font-semibold text-gray-900 mb-2">Electives</h4>
                    <p class="text-2xl font-bold text-coral mb-1">27 Credits</p>
                    <p class="text-sm text-gray-600">Specialization courses</p>
                </div>

                <div class="text-center">
                    <div
                        class="w-16 h-16 bg-gradient-to-r from-teal to-coral rounded-full flex items-center justify-center mx-auto mb-3">
                        <span class="text-white text-2xl">📚</span>
                    </div>
                    <h4 class="font-semibold text-gray-900 mb-2">General Education</h4>
                    <p class="text-2xl font-bold text-teal mb-1">30 Credits</p>
                    <p class="text-sm text-gray-600">Liberal arts, sciences</p>
                </div>
            </div>
        </div>
    </div>

    <script>
        // Tab functionality
        document.querySelectorAll('.year-tab').forEach(tab => {
            tab.addEventListener('click', function () {
                const year = this.dataset.year;

                // Remove active class from all tabs
                document.querySelectorAll('.year-tab').forEach(t => {
                    t.classList.remove('bg-white', 'text-coral', 'shadow-sm');
                    t.classList.add('text-gray-600');
                });

                // Add active class to clicked tab
                this.classList.add('bg-white', 'text-coral', 'shadow-sm');
                this.classList.remove('text-gray-600');

                // Hide all year content
                document.querySelectorAll('.year-content').forEach(content => {
                    content.classList.add('hidden');
                });

                // Show selected year content
                document.getElementById(`year-${year}`).classList.remove('hidden');
            });
        });

        // Add hover effects to course cards
        document.querySelectorAll('.course-card').forEach(card => {
            card.addEventListener('mouseenter', function () {
                this.style.borderColor = '#4ECDC4';
            });

            card.addEventListener('mouseleave', function () {
                this.style.borderColor = '#e5e7eb';
            });
        });
    </script>
