<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Grades - EduPortal</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        coral: '#FF6B6B',
                        teal: '#4ECDC4'
                    }
                }
            }
        }
    </script>
    <style>
        .grade-card {
            transition: all 0.3s ease;
        }

        .grade-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
        }

        .progress-bar {
            transition: width 0.8s ease-in-out;
        }
    </style>
</head>

<body class="bg-gray-50 min-h-screen">
    <!-- Header -->
    <header class="bg-white shadow-sm border-b-2 border-teal">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center py-4">
                <div class="flex items-center space-x-3">
                    <div
                        class="w-10 h-10 bg-gradient-to-r from-coral to-teal rounded-lg flex items-center justify-center">
                        <span class="text-white font-bold text-lg">📚</span>
                    </div>
                    <h1 class="text-2xl font-bold text-gray-800">EduPortal</h1>
                </div>
                <div class="flex items-center space-x-4">
                    <span class="text-gray-600">Welcome back, Alex!</span>
                    <div class="w-8 h-8 bg-teal rounded-full flex items-center justify-center">
                        <span class="text-white text-sm font-semibold">A</span>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <!-- Page Title and Summary -->
        <div class="mb-8">
            <h2 class="text-3xl font-bold text-gray-900 mb-2">My Grades</h2>
            <p class="text-gray-600">Track your academic progress across all subjects</p>

            <!-- Overall GPA Card -->
            <div class="mt-6 bg-gradient-to-r from-coral to-teal rounded-xl p-6 text-white">
                <div class="flex items-center justify-between">
                    <div>
                        <h3 class="text-lg font-semibold opacity-90">Overall GPA</h3>
                        <p class="text-3xl font-bold">3.7</p>
                        <p class="text-sm opacity-80">Spring 2024 Semester</p>
                    </div>
                    <div class="text-right">
                        <div class="text-2xl mb-2">🎯</div>
                        <p class="text-sm opacity-80">6 courses completed</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Filter Tabs -->
        <div class="mb-6">
            <div class="flex space-x-1 bg-gray-100 p-1 rounded-lg w-fit">
                <button class="px-4 py-2 rounded-md bg-white text-coral font-medium shadow-sm">Current Semester</button>
                <button class="px-4 py-2 rounded-md text-gray-600 hover:text-gray-800">All Time</button>
                <button class="px-4 py-2 rounded-md text-gray-600 hover:text-gray-800">Previous</button>
            </div>
        </div>

        <!-- Grades Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
            <!-- Mathematics -->
            <div class="grade-card bg-white rounded-xl p-6 shadow-sm border border-gray-100">
                <div class="flex items-center justify-between mb-4">
                    <div class="flex items-center space-x-3">
                        <div class="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center">
                            <span class="text-2xl">📐</span>
                        </div>
                        <div>
                            <h3 class="font-semibold text-gray-900">Mathematics</h3>
                            <p class="text-sm text-gray-500">MATH 201</p>
                        </div>
                    </div>
                    <div class="text-right">
                        <div class="text-2xl font-bold text-green-600">A-</div>
                        <div class="text-sm text-gray-500">92%</div>
                    </div>
                </div>
                <div class="space-y-2">
                    <div class="flex justify-between text-sm">
                        <span class="text-gray-600">Progress</span>
                        <span class="text-gray-800">92/100</span>
                    </div>
                    <div class="w-full bg-gray-200 rounded-full h-2">
                        <div class="progress-bar bg-green-500 h-2 rounded-full" style="width: 92%"></div>
                    </div>
                </div>
            </div>

            <!-- Physics -->
            <div class="grade-card bg-white rounded-xl p-6 shadow-sm border border-gray-100">
                <div class="flex items-center justify-between mb-4">
                    <div class="flex items-center space-x-3">
                        <div class="w-12 h-12 bg-purple-100 rounded-lg flex items-center justify-center">
                            <span class="text-2xl">⚛️</span>
                        </div>
                        <div>
                            <h3 class="font-semibold text-gray-900">Physics</h3>
                            <p class="text-sm text-gray-500">PHYS 101</p>
                        </div>
                    </div>
                    <div class="text-right">
                        <div class="text-2xl font-bold text-blue-600">B+</div>
                        <div class="text-sm text-gray-500">87%</div>
                    </div>
                </div>
                <div class="space-y-2">
                    <div class="flex justify-between text-sm">
                        <span class="text-gray-600">Progress</span>
                        <span class="text-gray-800">87/100</span>
                    </div>
                    <div class="w-full bg-gray-200 rounded-full h-2">
                        <div class="progress-bar bg-blue-500 h-2 rounded-full" style="width: 87%"></div>
                    </div>
                </div>
            </div>

            <!-- Chemistry -->
            <div class="grade-card bg-white rounded-xl p-6 shadow-sm border border-gray-100">
                <div class="flex items-center justify-between mb-4">
                    <div class="flex items-center space-x-3">
                        <div class="w-12 h-12 bg-green-100 rounded-lg flex items-center justify-center">
                            <span class="text-2xl">🧪</span>
                        </div>
                        <div>
                            <h3 class="font-semibold text-gray-900">Chemistry</h3>
                            <p class="text-sm text-gray-500">CHEM 150</p>
                        </div>
                    </div>
                    <div class="text-right">
                        <div class="text-2xl font-bold text-green-600">A</div>
                        <div class="text-sm text-gray-500">95%</div>
                    </div>
                </div>
                <div class="space-y-2">
                    <div class="flex justify-between text-sm">
                        <span class="text-gray-600">Progress</span>
                        <span class="text-gray-800">95/100</span>
                    </div>
                    <div class="w-full bg-gray-200 rounded-full h-2">
                        <div class="progress-bar bg-green-500 h-2 rounded-full" style="width: 95%"></div>
                    </div>
                </div>
            </div>

            <!-- English Literature -->
            <div class="grade-card bg-white rounded-xl p-6 shadow-sm border border-gray-100">
                <div class="flex items-center justify-between mb-4">
                    <div class="flex items-center space-x-3">
                        <div class="w-12 h-12 bg-red-100 rounded-lg flex items-center justify-center">
                            <span class="text-2xl">📖</span>
                        </div>
                        <div>
                            <h3 class="font-semibold text-gray-900">English Literature</h3>
                            <p class="text-sm text-gray-500">ENG 205</p>
                        </div>
                    </div>
                    <div class="text-right">
                        <div class="text-2xl font-bold text-yellow-600">B</div>
                        <div class="text-sm text-gray-500">83%</div>
                    </div>
                </div>
                <div class="space-y-2">
                    <div class="flex justify-between text-sm">
                        <span class="text-gray-600">Progress</span>
                        <span class="text-gray-800">83/100</span>
                    </div>
                    <div class="w-full bg-gray-200 rounded-full h-2">
                        <div class="progress-bar bg-yellow-500 h-2 rounded-full" style="width: 83%"></div>
                    </div>
                </div>
            </div>

            <!-- Computer Science -->
            <div class="grade-card bg-white rounded-xl p-6 shadow-sm border border-gray-100">
                <div class="flex items-center justify-between mb-4">
                    <div class="flex items-center space-x-3">
                        <div class="w-12 h-12 bg-indigo-100 rounded-lg flex items-center justify-center">
                            <span class="text-2xl">💻</span>
                        </div>
                        <div>
                            <h3 class="font-semibold text-gray-900">Computer Science</h3>
                            <p class="text-sm text-gray-500">CS 101</p>
                        </div>
                    </div>
                    <div class="text-right">
                        <div class="text-2xl font-bold text-green-600">A</div>
                        <div class="text-sm text-gray-500">96%</div>
                    </div>
                </div>
                <div class="space-y-2">
                    <div class="flex justify-between text-sm">
                        <span class="text-gray-600">Progress</span>
                        <span class="text-gray-800">96/100</span>
                    </div>
                    <div class="w-full bg-gray-200 rounded-full h-2">
                        <div class="progress-bar bg-green-500 h-2 rounded-full" style="width: 96%"></div>
                    </div>
                </div>
            </div>

            <!-- History -->
            <div class="grade-card bg-white rounded-xl p-6 shadow-sm border border-gray-100">
                <div class="flex items-center justify-between mb-4">
                    <div class="flex items-center space-x-3">
                        <div class="w-12 h-12 bg-yellow-100 rounded-lg flex items-center justify-center">
                            <span class="text-2xl">🏛️</span>
                        </div>
                        <div>
                            <h3 class="font-semibold text-gray-900">World History</h3>
                            <p class="text-sm text-gray-500">HIST 102</p>
                        </div>
                    </div>
                    <div class="text-right">
                        <div class="text-2xl font-bold text-blue-600">B+</div>
                        <div class="text-sm text-gray-500">89%</div>
                    </div>
                </div>
                <div class="space-y-2">
                    <div class="flex justify-between text-sm">
                        <span class="text-gray-600">Progress</span>
                        <span class="text-gray-800">89/100</span>
                    </div>
                    <div class="w-full bg-gray-200 rounded-full h-2">
                        <div class="progress-bar bg-blue-500 h-2 rounded-full" style="width: 89%"></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Recent Activity -->
        <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
            <h3 class="text-xl font-semibold text-gray-900 mb-4">Recent Grade Updates</h3>
            <div class="space-y-4">
                <div class="flex items-center justify-between p-4 bg-gray-50 rounded-lg">
                    <div class="flex items-center space-x-3">
                        <div class="w-10 h-10 bg-green-100 rounded-full flex items-center justify-center">
                            <span class="text-green-600 font-semibold">A</span>
                        </div>
                        <div>
                            <p class="font-medium text-gray-900">Chemistry Lab Report #3</p>
                            <p class="text-sm text-gray-500">CHEM 150 • 2 days ago</p>
                        </div>
                    </div>
                    <span class="text-green-600 font-semibold">95/100</span>
                </div>

                <div class="flex items-center justify-between p-4 bg-gray-50 rounded-lg">
                    <div class="flex items-center space-x-3">
                        <div class="w-10 h-10 bg-blue-100 rounded-full flex items-center justify-center">
                            <span class="text-blue-600 font-semibold">B+</span>
                        </div>
                        <div>
                            <p class="font-medium text-gray-900">Physics Midterm Exam</p>
                            <p class="text-sm text-gray-500">PHYS 101 • 1 week ago</p>
                        </div>
                    </div>
                    <span class="text-blue-600 font-semibold">87/100</span>
                </div>

                <div class="flex items-center justify-between p-4 bg-gray-50 rounded-lg">
                    <div class="flex items-center space-x-3">
                        <div class="w-10 h-10 bg-green-100 rounded-full flex items-center justify-center">
                            <span class="text-green-600 font-semibold">A-</span>
                        </div>
                        <div>
                            <p class="font-medium text-gray-900">Math Assignment #8</p>
                            <p class="text-sm text-gray-500">MATH 201 • 1 week ago</p>
                        </div>
                    </div>
                    <span class="text-green-600 font-semibold">92/100</span>
                </div>
            </div>
        </div>
    </div>

    <script>
        // Animate progress bars on page load
        window.addEventListener('load', function () {
            const progressBars = document.querySelectorAll('.progress-bar');
            progressBars.forEach(bar => {
                const width = bar.style.width;
                bar.style.width = '0%';
                setTimeout(() => {
                    bar.style.width = width;
                }, 500);
            });
        });

        // Add click functionality to filter tabs
        document.querySelectorAll('button').forEach(button => {
            button.addEventListener('click', function () {
                // Remove active class from all buttons
                document.querySelectorAll('button').forEach(btn => {
                    btn.classList.remove('bg-white', 'text-coral', 'shadow-sm');
                    btn.classList.add('text-gray-600');
                });

                // Add active class to clicked button
                this.classList.add('bg-white', 'text-coral', 'shadow-sm');
                this.classList.remove('text-gray-600');
            });
        });
    </script>
